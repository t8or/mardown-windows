{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["md", "mdx", "markdown", "mdown", "mkd", "mkdn", "mdwn"], "name": "Markdown File" },
      { "ext": ["rmd"], "name": "R Markdown File" }
    ]
  },
  "productName": "Markdown Reader",
  "version": "0.1.0",
  "identifier": "com.markdownreader.app",
  "plugins": {
    "process": {
      "active": true
    },
    "dialog": {},
    "fs": {}
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Markdown Reader",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ]
  }
}
